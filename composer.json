{
    "name": "webrek/laravel-feature-flags",
    "description": "Feature flags for Laravel with percentage rollouts, rule-based targeting and A/B variants.",
    "keywords": [
        "laravel",
        "laravel-package",
        "feature-flags",
        "feature-toggle",
        "rollout",
        "ab-testing",
        "targeting",
        "experiments",
        "toggle"
    ],
    "homepage": "https://github.com/webrek/laravel-feature-flags",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Victor Hernandez",
            "email": "victor@arturohernandez.com.mx"
        }
    ],
    "support": {
        "issues": "https://github.com/webrek/laravel-feature-flags/issues",
        "source": "https://github.com/webrek/laravel-feature-flags",
        "security": "https://github.com/webrek/laravel-feature-flags/security/advisories/new"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Webrek\\FeatureFlags\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Webrek\\FeatureFlags\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webrek\\FeatureFlags\\FeatureFlagsServiceProvider"
            ],
            "aliases": {
                "Features": "Webrek\\FeatureFlags\\Facades\\Features"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "pint:check": "pint --test"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
